{
  "expo": {
    "name": "UniMente",
    "slug": "unimente",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "unimente",
    "userInterfaceStyle": "dark",
    "experiments": {
      "reactCompiler": false,
      "typedRoutes": true
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.unimente.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      },
      "package": "com.unimente.app",
      "versionCode": 1,
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0d1117"
        }
      ]
    ],
    "extra": {
      "API_URL":      "https://uni-mente-production.up.railway.app/graphql",
      "API_REST_URL": "https://uni-mente-production.up.railway.app",
      "eas": {
        "projectId": ""
      }
    }
  }
}
