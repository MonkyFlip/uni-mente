# ================================================================
#  UniMente — Variables de entorno del Backend
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas .env a Git — está en .gitignore.
# ================================================================


# ─── Base de datos MySQL ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=unimente
DB_SYNCHRONIZE=false


# ─── Autenticación JWT ───────────────────────────────────────────
# Cambia este valor por una cadena larga y aleatoria en producción.
JWT_SECRET=cambia_este_secreto_en_produccion
JWT_EXPIRES=8h


# ─── Restauración de emergencia ──────────────────────────────────
# Clave para usar /api/emergency-restore cuando la BD está vacía.
# Solo funciona si la tabla Usuario tiene 0 registros.
# Usa una clave única, larga y difícil de adivinar.
RESTORE_SECRET=UniMente_Restore_2024_SuperSecreta


# ─── Servidor ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development